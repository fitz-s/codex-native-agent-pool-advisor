{
  "name": "codex-native-agent-pool-advisor",
  "version": "0.2.2",
  "description": "Codex Desktop/CLI hook that prevents native subagent pool cap collisions and stale-open edge exhaustion.",
  "type": "module",
  "author": "Fitz",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/fitz-s/codex-native-agent-pool-advisor.git"
  },
  "bugs": {
    "url": "https://github.com/fitz-s/codex-native-agent-pool-advisor/issues"
  },
  "homepage": "https://fitz-s.github.io/codex-native-agent-pool-advisor/",
  "packageManager": "npm@11.8.0",
  "engines": {
    "node": ">=22"
  },
  "bin": {
    "codex-native-agent-pool-advisor-install": "scripts/install.mjs",
    "codex-native-agent-pool-advisor-doctor": "scripts/doctor.mjs",
    "codex-native-agent-pool-advisor-reset": "scripts/reset-pool.mjs",
    "codex-native-agent-pool-advisor-uninstall": "scripts/uninstall.mjs"
  },
  "files": [
    "hooks/",
    "scripts/",
    "docs/",
    "README.md",
    "CONTRIBUTING.md",
    "SECURITY.md",
    "LICENSE"
  ],
  "scripts": {
    "check": "node --check hooks/native-agent-pool-advisor.mjs && node --check scripts/install.mjs && node --check scripts/reset-pool.mjs && node --check scripts/doctor.mjs && node --check scripts/uninstall.mjs",
    "test": "node --test test/*.test.mjs"
  }
}
